# Pipeline calls keep transformations readable from left to right.
fn bracket(value: str, left: str, right: str) -> str:
    return left + value + right
let label = "  Rainbow  " |> trim |> lower |> bracket("[", "]")
let words = "fast safe beautiful" |> split(" ")
let joined = words |> join(" | ")
assert(label == "[rainbow]")
assert(label |> contains("rainbow"))
assert(joined == "fast | safe | beautiful")
print(label)
print(joined)
