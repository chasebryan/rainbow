fn sum_to(limit: i64) -> i64:
    var total = 0
    for value in range(1, limit + 1):
        total = total + value
    return total
let values = [3, 5, 8, 13]
let same_values = [3, 5, 8, 13]
let extended = append(values, 21)
let middle = slice(extended, 1, 4)
let built_from_empty = append(append([], 3), 5)
let fallback_row: [i64] = get([], 0, [])
let reversed = reverse(extended)
let reversed_empty: [i64] = reverse([])
let cleaned = trim("  Fast Secure Simple  ")
let words = split(lower(cleaned), " ")
var rebuilt_name = ""
for ch in "Rainbow":
    rebuilt_name = rebuilt_name + ch
assert(sum_to(10) == 55, "sum_to should add an inclusive range")
assert(len(values) == 4)
assert(is_empty([]), "empty array literals should be testable")
assert(not is_empty(values), "non-empty arrays should report false")
assert(values[2] == 8, "array indexing should stay checked and stable")
assert(values == same_values, "arrays should compare by value")
assert(extended == [3, 5, 8, 13, 21], "array append should preserve order")
assert(built_from_empty == [3, 5], "append should infer empty array literals")
assert(middle == [5, 8, 13], "array slicing should preserve element order")
assert(reversed == [21, 13, 8, 5, 3], "reverse should flip array order")
assert(is_empty(reversed_empty), "reverse should preserve typed empty arrays")
assert(first(extended, -1) == 3, "first should read the first array element")
assert(last(extended, -1) == 21, "last should read the last array element")
assert(first([], 42) == 42, "first should use fallback for empty arrays")
assert(last([], 42) == 42, "last should use fallback for empty arrays")
assert(get(extended, 2, -1) == 8, "get should return in-bounds array elements")
assert(get(extended, 99, -1) == -1, "get should return fallback for missing array indexes")
assert(find(extended, 13) == 3, "find should return the first matching array index")
assert(find(extended, 34) == -1, "find should return -1 for missing array values")
assert(find([], 34) == -1, "find should accept empty array literals")
assert(count([3, 5, 3, 8, 3], 3) == 3, "count should find every matching array value")
assert(count(extended, 34) == 0, "count should return zero for missing array values")
assert(count([], 34) == 0, "count should accept empty array literals")
assert(is_empty(fallback_row), "get should use annotated empty array fallbacks")
assert(contains(extended, 21), "array contains should use value equality")
assert(not contains(extended, 34) and contains(extended, 21))
assert(contains("secure Rainbow", "Rainbow"), "string contains should find substrings")
assert("Rainbow"[0] == "R", "string indexing should return one-character strings")
assert("Rainbow"[1] == "a", "string indexing should use character indexes")
assert(rebuilt_name == "Rainbow", "strings should be iterable by character")
assert(cleaned == "Fast Secure Simple", "trim should remove surrounding whitespace")
assert(lower("RAINBOW") == "rainbow", "lower should normalize uppercase strings")
assert(upper("rainbow") == "RAINBOW", "upper should normalize lowercase strings")
assert(starts_with(cleaned, "Fast"), "starts_with should check prefixes")
assert(ends_with(cleaned, "Simple"), "ends_with should check suffixes")
assert(replace(cleaned, "Simple", "Readable") == "Fast Secure Readable", "replace should substitute substrings")
assert(words == ["fast", "secure", "simple"], "split should produce string arrays")
assert(join(words, "-") == "fast-secure-simple", "join should combine string arrays")
assert(join([], ",") == "", "join should accept empty array literals")
assert(slice("secure Rainbow", 0, 6) == "secure", "string slicing should use character bounds")
assert(get("Rainbow", 1, "?") == "a", "string get should return one-character strings")
assert(get("Rainbow", 99, "?") == "?", "string get should return fallback when missing")
assert(reverse("Rainbow") == "wobniaR", "reverse should flip string characters")
assert(first("Rainbow", "?") == "R", "first should read the first string character")
assert(last("Rainbow", "?") == "w", "last should read the last string character")
assert(first("", "?") == "?", "first should use fallback for empty strings")
assert(last("", "?") == "?", "last should use fallback for empty strings")
assert(find("secure Rainbow", "Rainbow") == 7, "string find should return character indexes")
assert(find("secure Rainbow", "missing") == -1, "string find should return -1 when missing")
assert(count("secure Rainbow secure", "secure") == 2, "string count should find substrings")
assert(count("aaaa", "aa") == 2, "string count should use non-overlapping matches")
assert(count("Rainbow", "") == 0, "string count should ignore empty needles")
assert(is_empty(""), "empty strings should report true")
assert(not is_empty("Rainbow"), "non-empty strings should report false")
assert(contains("secure Rainbow", "Rainbow") or false)
